# Godot 4+ specific ignores
.godot/

# Imported translations (automatically generated from CSV files)
*.translation

# Mono/.NET specific ignores
.mono/
data_*/
mono_crash.*.json

# System/editor files
.DS_Store

# Screenshots from tools/shot.tscn
.shots/

# Python bytecode from tools/
__pycache__/

# Atomic-save temp from the farm designer
*.json.tmp

# Exported build artifacts (APKs etc.)
build/
# Android v4 incremental-install signature — only used by `adb install --incremental`,
# not needed to sideload the committed debug APK, so keep it out of the repo.
*.idsig

# Local deploy credentials (never commit secrets)
.deploy/
